# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net
MONGODB_DB=watervibes

# Resend (Phase 4)
RESEND_API_KEY=re_your_key_here
CONTACT_EMAIL=owner@example.com
FROM_EMAIL=onboarding@resend.dev
# Phase 4: public mirror of CONTACT_EMAIL — safe to expose in the client bundle.
# Used by the ContactForm error toast as a fallback address.
NEXT_PUBLIC_CONTACT_EMAIL=owner@example.com

# Admin auth
# IMPORTANT: bcrypt hashes contain `$`, which @next/env's dotenv-expand treats as
# variable references (single quotes do NOT prevent this in @next/env). You MUST
# escape every `$` with a backslash, e.g. \$2a\$10\$… Otherwise the hash loaded
# into process.env will be silently corrupted and every login will fail.
ADMIN_PASSWORD_HASH=\$2a\$10\$replace_with_bcrypt_hash
JWT_SECRET=replace_with_32_plus_random_bytes

# Public site URL — used for canonical links, sitemap, robots, OG tags,
# and every absolute URL baked into structured data. Must be the exact
# production origin (scheme + host, no trailing slash). In dev, leave
# as http://localhost:3000 so previews resolve correctly.
NEXT_PUBLIC_SITE_URL=https://watervibe.ro
